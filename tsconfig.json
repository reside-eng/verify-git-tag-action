{
  "compilerOptions": {
    "target": "es6",
    "module": "commonjs",
    "lib": [
      "es6"
    ],
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "noImplicitAny": true,
    "skipLibCheck": true,
    "esModuleInterop": true
  },
  "exclude": ["node_modules", "**/*.test.ts"],
  "include": [
    "./src/index.d.ts",
    "./src"
  ],
  "typeRoots": [
    "./src/index.d.ts",
    "./node_modules/@types"
  ]
}